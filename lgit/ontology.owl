<?xml version="1.0"?>
<rdf:RDF
    xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
    xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
    xmlns:owl="http://www.w3.org/2002/07/owl#"
    xmlns:camera="http://example.com/camera#">

    <!-- Ontology header -->
    <owl:Ontology rdf:about="http://example.com/camera"/>

    <!-- Classes -->
    <owl:Class rdf:about="http://example.com/camera#ManufacturingProcess"/>
    <owl:Class rdf:about="http://example.com/camera#ProcessStep">
        <rdfs:subClassOf rdf:resource="http://example.com/camera#ManufacturingProcess"/>
    </owl:Class>
    <owl:Class rdf:about="http://example.com/camera#Equipment"/>
    <owl:Class rdf:about="http://example.com/camera#Component"/>
    <owl:Class rdf:about="http://example.com/camera#Material"/>

    <!-- Object properties -->
    <owl:ObjectProperty rdf:about="http://example.com/camera#hasSubProcess">
        <rdfs:domain rdf:resource="http://example.com/camera#ProcessStep"/>
        <rdfs:range rdf:resource="http://example.com/camera#ProcessStep"/>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="http://example.com/camera#precedes">
        <rdfs:domain rdf:resource="http://example.com/camera#ProcessStep"/>
        <rdfs:range rdf:resource="http://example.com/camera#ProcessStep"/>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="http://example.com/camera#usesEquipment">
        <rdfs:domain rdf:resource="http://example.com/camera#ProcessStep"/>
        <rdfs:range rdf:resource="http://example.com/camera#Equipment"/>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="http://example.com/camera#involvesComponent">
        <rdfs:domain rdf:resource="http://example.com/camera#ProcessStep"/>
        <rdfs:range rdf:resource="http://example.com/camera#Component"/>
    </owl:ObjectProperty>

    <!-- Process steps (Individuals) -->
    <owl:NamedIndividual rdf:about="http://example.com/camera#WaferDicing">
        <rdf:type rdf:resource="http://example.com/camera#ProcessStep"/>
        <camera:precedes rdf:resource="http://example.com/camera#SensorAssembly"/>
        <camera:usesEquipment rdf:resource="http://example.com/camera#DicingMachine"/>
        <camera:usesEquipment rdf:resource="http://example.com/camera#WaferCleaningSystem"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://example.com/camera#SensorAssembly">
        <rdf:type rdf:resource="http://example.com/camera#ProcessStep"/>
        <camera:precedes rdf:resource="http://example.com/camera#SMTAssembly"/>
        <camera:usesEquipment rdf:resource="http://example.com/camera#DieBonder"/>
        <camera:usesEquipment rdf:resource="http://example.com/camera#WireBonder"/>
        <camera:usesEquipment rdf:resource="http://example.com/camera#EpoxyDispenser"/>
        <camera:usesEquipment rdf:resource="http://example.com/camera#EncapsulationEquipment"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://example.com/camera#SMTAssembly">
        <rdf:type rdf:resource="http://example.com/camera#ProcessStep"/>
        <camera:precedes rdf:resource="http://example.com/camera#LensManufacturing"/>
        <camera:usesEquipment rdf:resource="http://example.com/camera#SolderPastePrinter"/>
        <camera:usesEquipment rdf:resource="http://example.com/camera#PickAndPlaceMachine"/>
        <camera:usesEquipment rdf:resource="http://example.com/camera#ReflowOven"/>
        <camera:usesEquipment rdf:resource="http://example.com/camera#AOIInspector"/>
        <camera:usesEquipment rdf:resource="http://example.com/camera#XRayInspector"/>
        <camera:usesEquipment rdf:resource="http://example.com/camera#UltrasonicCleaner"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://example.com/camera#LensManufacturing">
        <rdf:type rdf:resource="http://example.com/camera#ProcessStep"/>
        <camera:precedes rdf:resource="http://example.com/camera#VCMAssembly"/>
        <camera:usesEquipment rdf:resource="http://example.com/camera#MoldPress"/>
        <camera:usesEquipment rdf:resource="http://example.com/camera#LensPolishingMachine"/>
        <camera:usesEquipment rdf:resource="http://example.com/camera#CoatingEquipment"/>
        <camera:usesEquipment rdf:resource="http://example.com/camera#LensInspectionEquipment"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://example.com/camera#VCMAssembly">
        <rdf:type rdf:resource="http://example.com/camera#ProcessStep"/>
        <camera:precedes rdf:resource="http://example.com/camera#LensFilterAssembly"/>
        <camera:usesEquipment rdf:resource="http://example.com/camera#VCMAssemblyMachine"/>
        <camera:usesEquipment rdf:resource="http://example.com/camera#MemsOisInserter"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://example.com/camera#LensFilterAssembly">
        <rdf:type rdf:resource="http://example.com/camera#ProcessStep"/>
        <camera:precedes rdf:resource="http://example.com/camera#ActiveAlignmentCalibration"/>
        <camera:usesEquipment rdf:resource="http://example.com/camera#ActiveAlignmentSystem"/>
        <camera:usesEquipment rdf:resource="http://example.com/camera#GlueDispenser"/>
        <camera:usesEquipment rdf:resource="http://example.com/camera#UVLED"/>
        <camera:usesEquipment rdf:resource="http://example.com/camera#ThermalOven"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://example.com/camera#ActiveAlignmentCalibration">
        <rdf:type rdf:resource="http://example.com/camera#ProcessStep"/>
        <camera:precedes rdf:resource="http://example.com/camera#FocusAdjustment"/>
        <camera:usesEquipment rdf:resource="http://example.com/camera#ActiveAlignmentSystem"/>
        <camera:usesEquipment rdf:resource="http://example.com/camera#GlueDispenser"/>
        <camera:usesEquipment rdf:resource="http://example.com/camera#UVLED"/>
        <camera:usesEquipment rdf:resource="http://example.com/camera#ThermalOven"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://example.com/camera#FocusAdjustment">
        <rdf:type rdf:resource="http://example.com/camera#ProcessStep"/>
        <camera:precedes rdf:resource="http://example.com/camera#OpticalCalibration"/>
        <camera:usesEquipment rdf:resource="http://example.com/camera#FocusAdjustmentMachine"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://example.com/camera#OpticalCalibration">
        <rdf:type rdf:resource="http://example.com/camera#ProcessStep"/>
        <camera:precedes rdf:resource="http://example.com/camera#FunctionalTesting"/>
        <camera:usesEquipment rdf:resource="http://example.com/camera#MTFTester"/>
        <camera:usesEquipment rdf:resource="http://example.com/camera#DistortionTester"/>
        <camera:usesEquipment rdf:resource="http://example.com/camera#SpectralTester"/>
        <camera:usesEquipment rdf:resource="http://example.com/camera#IntegratingSphere"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://example.com/camera#FunctionalTesting">
        <rdf:type rdf:resource="http://example.com/camera#ProcessStep"/>
        <camera:precedes rdf:resource="http://example.com/camera#ReliabilityTesting"/>
        <camera:usesEquipment rdf:resource="http://example.com/camera#FunctionalTester"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://example.com/camera#ReliabilityTesting">
        <rdf:type rdf:resource="http://example.com/camera#ProcessStep"/>
        <camera:precedes rdf:resource="http://example.com/camera#Packaging"/>
        <camera:usesEquipment rdf:resource="http://example.com/camera#EnvironmentalChamber"/>
        <camera:usesEquipment rdf:resource="http://example.com/camera#VibrationTester"/>
        <camera:usesEquipment rdf:resource="http://example.com/camera#DustTester"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://example.com/camera#Packaging">
        <rdf:type rdf:resource="http://example.com/camera#ProcessStep"/>
        <camera:usesEquipment rdf:resource="http://example.com/camera#PackagingSystem"/>
    </owl:NamedIndividual>

    <!-- Equipment individuals -->
    <owl:NamedIndividual rdf:about="http://example.com/camera#DicingMachine">
        <rdf:type rdf:resource="http://example.com/camera#Equipment"/>
    </owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="http://example.com/camera#WaferCleaningSystem">
        <rdf:type rdf:resource="http://example.com/camera#Equipment"/>
    </owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="http://example.com/camera#DieBonder">
        <rdf:type rdf:resource="http://example.com/camera#Equipment"/>
    </owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="http://example.com/camera#WireBonder">
        <rdf:type rdf:resource="http://example.com/camera#Equipment"/>
    </owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="http://example.com/camera#EpoxyDispenser">
        <rdf:type rdf:resource="http://example.com/camera#Equipment"/>
    </owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="http://example.com/camera#EncapsulationEquipment">
        <rdf:type rdf:resource="http://example.com/camera#Equipment"/>
    </owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="http://example.com/camera#SolderPastePrinter">
        <rdf:type rdf:resource="http://example.com/camera#Equipment"/>
    </owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="http://example.com/camera#PickAndPlaceMachine">
        <rdf:type rdf:resource="http://example.com/camera#Equipment"/>
    </owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="http://example.com/camera#ReflowOven">
        <rdf:type rdf:resource="http://example.com/camera#Equipment"/>
    </owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="http://example.com/camera#AOIInspector">
        <rdf:type rdf:resource="http://example.com/camera#Equipment"/>
    </owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="http://example.com/camera#XRayInspector">
        <rdf:type rdf:resource="http://example.com/camera#Equipment"/>
    </owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="http://example.com/camera#UltrasonicCleaner">
        <rdf:type rdf:resource="http://example.com/camera#Equipment"/>
    </owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="http://example.com/camera#MoldPress">
        <rdf:type rdf:resource="http://example.com/camera#Equipment"/>
    </owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="http://example.com/camera#LensPolishingMachine">
        <rdf:type rdf:resource="http://example.com/camera#Equipment"/>
    </owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="http://example.com/camera#CoatingEquipment">
        <rdf:type rdf:resource="http://example.com/camera#Equipment"/>
    </owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="http://example.com/camera#LensInspectionEquipment">
        <rdf:type rdf:resource="http://example.com/camera#Equipment"/>
    </owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="http://example.com/camera#VCMAssemblyMachine">
        <rdf:type rdf:resource="http://example.com/camera#Equipment"/>
    </owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="http://example.com/camera#MemsOisInserter">
        <rdf:type rdf:resource="http://example.com/camera#Equipment"/>
    </owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="http://example.com/camera#ActiveAlignmentSystem">
        <rdf:type rdf:resource="http://example.com/camera#Equipment"/>
    </owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="http://example.com/camera#GlueDispenser">
        <rdf:type rdf:resource="http://example.com/camera#Equipment"/>
    </owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="http://example.com/camera#UVLED">
        <rdf:type rdf:resource="http://example.com/camera#Equipment"/>
    </owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="http://example.com/camera#ThermalOven">
        <rdf:type rdf:resource="http://example.com/camera#Equipment"/>
    </owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="http://example.com/camera#FocusAdjustmentMachine">
        <rdf:type rdf:resource="http://example.com/camera#Equipment"/>
    </owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="http://example.com/camera#MTFTester">
        <rdf:type rdf:resource="http://example.com/camera#Equipment"/>
    </owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="http://example.com/camera#DistortionTester">
        <rdf:type rdf:resource="http://example.com/camera#Equipment"/>
    </owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="http://example.com/camera#SpectralTester">
        <rdf:type rdf:resource="http://example.com/camera#Equipment"/>
    </owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="http://example.com/camera#IntegratingSphere">
        <rdf:type rdf:resource="http://example.com/camera#Equipment"/>
    </owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="http://example.com/camera#FunctionalTester">
        <rdf:type rdf:resource="http://example.com/camera#Equipment"/>
    </owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="http://example.com/camera#EnvironmentalChamber">
        <rdf:type rdf:resource="http://example.com/camera#Equipment"/>
    </owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="http://example.com/camera#VibrationTester">
        <rdf:type rdf:resource="http://example.com/camera#Equipment"/>
    </owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="http://example.com/camera#DustTester">
        <rdf:type rdf:resource="http://example.com/camera#Equipment"/>
    </owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="http://example.com/camera#PackagingSystem">
        <rdf:type rdf:resource="http://example.com/camera#Equipment"/>
    </owl:NamedIndividual>

</rdf:RDF>
